@startuml PowerManagementStateMachine
title Power Management State Machine (sdf_power)

scale 1.2
skinparam StateBackgroundColor #e8f4f8
skinparam StateBorderColor #1a5276
skinparam ArrowColor #1a5276

[*] --> INITIALIZING : Boot
INITIALIZING --> ACTIVE : Init Complete

state ACTIVE {
  [*] --> IDLE : Loop Interval (250ms)
  
  state IDLE {
    IDLE : Check Battery Reporting Interval
    IDLE : Check Activity Timers
  }

  state EVALUATE_SLEEP <<choice>>
  
  IDLE --> EVALUATE_SLEEP : Evaluate Conditions
  
  EVALUATE_SLEEP --> IDLE : [Sleep Disabled OR\nIn Post-Wake Guard OR\nActivity < Idle Timeout OR\nSystem Busy]

  EVALUATE_SLEEP --> PREPARE_SLEEP : [All Sleep Conditions Met]
  
  state PREPARE_SLEEP {
    PREPARE_SLEEP : 1. Configure Timer Wakeup
    PREPARE_SLEEP : 2. Configure GPIO Wakeup
    PREPARE_SLEEP : 3. Disable Fingerprint Sensor Power (RST = LOW)
    PREPARE_SLEEP : 4. Disable BLE Radio (Optional)
  }
}

PREPARE_SLEEP --> LIGHT_SLEEP : esp_light_sleep_start()

state LIGHT_SLEEP #E8DAEF {
  LIGHT_SLEEP : CPU Halted
  LIGHT_SLEEP : Memory Retained
  LIGHT_SLEEP : Wake Sources Active
}

LIGHT_SLEEP --> WAKING : Hardware Interrupt\n(Timer or GPIO)

state WAKING {
  WAKING : 1. Re-enable BLE Radio (Optional)
  WAKING : 2. Notify Wake Reason
  WAKING : 3. Reset Activity/Guard Timers
  WAKING : 4. Enable Fingerprint Power (RST = HIGH)
  WAKING : 5. Wait 200ms (Fingerprint Boot Delay)
}

WAKING --> ACTIVE : Wake Complete

@enduml

menu "SDF BLE Transport"

choice SDF_BLE_CONNECTION_MODE
    prompt "BLE connection policy"
    default SDF_BLE_CONNECTION_MODE_ALWAYS_CONNECTED
    help
        Controls whether the firmware keeps the Nuki BLE link active
        continuously or connects only when pairing or an action requires it.

config SDF_BLE_CONNECTION_MODE_ALWAYS_CONNECTED
    bool "Stay connected all the time"
    help
        Start scanning automatically when a target address is available and
        reconnect automatically after disconnects.

config SDF_BLE_CONNECTION_MODE_ON_DEMAND
    bool "Connect on demand"
    help
        Defer scanning until pairing or a lock-state / lock-action request
        needs the transport, then release the BLE link again once the request
        completes.

endchoice

config SDF_BLE_CONNECT_TIMEOUT_MS
    int "BLE connection attempt timeout (ms)"
    range 1000 30000
    default 10000
    help
        Maximum duration to wait for a BLE connection to complete.
        If the connection is not established within this time,
        ble_gap_conn_cancel() is called and a reconnect is scheduled.

config SDF_BLE_RECONNECT_BASE_DELAY_MS
    int "Reconnect base delay (ms)"
    range 100 10000
    default 1000
    help
        Initial delay before the first reconnection attempt.
        Each subsequent attempt doubles this delay up to the maximum.

config SDF_BLE_RECONNECT_MAX_DELAY_MS
    int "Reconnect maximum delay (ms)"
    range 1000 120000
    default 30000
    help
        Upper bound for the exponential backoff delay between
        reconnection attempts.

config SDF_BLE_RECONNECT_MAX_RETRIES
    int "Maximum reconnect attempts (0=unlimited)"
    range 0 100
    default 10
    help
        Maximum number of consecutive reconnection attempts before
        giving up. Set to 0 for unlimited retries. After exhaustion,
        sdf_nuki_ble_start() must be called again to restart.

endmenu
